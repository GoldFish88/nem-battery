# nem-battery frontend — environment variables
# Copy this file to .env.local for local development.

# ────────────────────────────────────────────────────────────────
# DATABASE_URL
#
# Local development (DuckDB file, relative to the frontend/ dir):
DATABASE_URL=../nem_battery.db
#
# Remote (MotherDuck cloud):
# DATABASE_URL=md:nem_battery
# ────────────────────────────────────────────────────────────────

# MotherDuck token — required when DATABASE_URL starts with "md:"
# Set this in Vercel project env vars for production.
# MOTHERDUCK_TOKEN=your_token_here
